# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/forexzim
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8090

# ── Scraping ──────────────────────────────────────────────────────────────────
SCRAPE_INTERVAL_MS=1800000
SCRAPE_RETENTION_DAYS=7

# ── Email alerts (leave MAIL_USERNAME blank to disable) ───────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
ALERTS_FROM_EMAIL=noreply@forexzim.co.zw
